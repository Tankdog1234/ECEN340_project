# ==========================================
# Vivado Project Files
# ==========================================
# Ignored because the project will be recreated via Tcl script
*.xpr

# ==========================================
# Vivado Directory and Workspace Dumps
# ==========================================
# Blocks the massive local directories Vivado generates automatically
*.cache/
*.hw/
*.sim/
*.ip_user_files/
*.runs/
.Xil/
_x/

# ==========================================
# Vivado Log, Journal, and Process Files
# ==========================================
# Tracks runtime logs, window states, and process IDs
*.log
*.jou
*.pb
*.str
vivado_pid*.str
vivado_pid*.zip

# ==========================================
# Generated Hardware & Wrapper Artifacts
# ==========================================
# Automatically generated top-level HDL wrappers for block designs
*_wrapper.v
*_wrapper.vhd
# Hardware handoff files and system definitions for Vitis/SDK
*.xsa
*.sysdef
# Design Checkpoints and reports (Vivado will regenerate these during runs)
*.dcp
*.rpt

# ==========================================
# Vivado Backup & Auto-Save Files
# ==========================================
*.backup.*
*~

# ==========================================
# Vitis / Embedded SDK Workspace Artifacts
# ==========================================
# Keeps C/C++ firmware workspace junk out of the repository
.metadata/
.analytics/
Workspace/
ide.log
*.spc

# ==========================================
# OS Clean-up
# ==========================================
.DS_Store
Thumbs.db